<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Add internet permission if not already present -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:theme="@style/Theme.BookingApp"
        tools:targetApi="31">

        <!-- Main Activity -->
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Dashboard Activity -->
        <activity
            android:name=".DashboardActivity"
            android:exported="false" />

        <!-- CategoryServicesActivity -->
        <activity android:name=".CategoryServicesActivity" android:exported="false" />

        <!-- ADDED: AppointmentsActivity -->
        <activity android:name=".AppointmentsActivity" android:exported="false" />

        <!-- ADDED: ProfileActivity -->
        <activity android:name=".ProfileActivity" android:exported="false" />

        <!-- All Other Activities -->
        <activity android:name=".BookingsActivity" android:exported="false" />
        <activity android:name=".StatisticsActivity" android:exported="false" />
        <activity android:name=".UploadServiceActivity" android:exported="false" />
        <activity android:name=".UpdateServiceActivity" android:exported="false" />
        <activity android:name=".DeleteServiceActivity" android:exported="false" />
        <activity android:name=".RegisterActivity" android:exported="false" />
        <activity android:name=".CategoryActivity" android:exported="false" />
        <activity android:name=".HairStylesActivity" android:exported="false" />
        <activity android:name=".LashStylesActivity" android:exported="false" />
        <activity android:name=".NailStylesActivity" android:exported="false" />
        <activity android:name=".BookingSelectActivity" android:exported="false" />
        <activity android:name=".BookingDetailsActivity" android:exported="false" />
        <activity android:name=".PaymentActivity" android:label="Payment" />
        <activity android:name=".BookingConfirmationActivity" android:label="Confirmation" />
        <activity android:name=".ChangePasswordActivity" android:label="Change Password" />"
        <activity android:name=".EditProfileActivity" android:label="Change Password" />"
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>
</manifest>